# Runtime secrets — read by Next.js standalone server at startup.
# Copy to .env.production.local and fill in values.
# This file is gitignored (.env.*.local).

# Generate with: openssl rand -hex 32
NEXTAUTH_SECRET=CHANGE_ME

NEXTAUTH_URL=https://new.ligavpv.com
API_INTERNAL_URL=http://127.0.0.1:8000/api
