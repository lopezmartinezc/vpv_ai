# Backend environment variables — copy to .env and fill in real values
DATABASE_URL=postgresql+asyncpg://vpv:CHANGE_ME@localhost:5432/ligavpv
DEBUG=true
ENVIRONMENT=development
LOG_LEVEL=INFO

# Auth
JWT_SECRET_KEY=CHANGE-ME-IN-PRODUCTION
JWT_EXPIRE_MINUTES=480

# Invites
INVITE_BASE_URL=http://localhost:3000/registro
INVITE_EXPIRY_DAYS=7

# CORS
CORS_ORIGINS=["http://localhost:3000"]

# Telegram (leave empty to disable)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ENABLED=false
