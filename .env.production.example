# Liga VPV — Production environment variables
# Copy to the appropriate location and fill in real values.
#
# Backend: /opt/vpv/backend/.env
# Frontend: set in PM2 ecosystem.config.js or /opt/vpv/frontend/.env

# ─── Backend ───────────────────────────────────────────────
ENVIRONMENT=production
DEBUG=false
LOG_LEVEL=INFO

# Database — use PG_* vars (password auto-escaped, safe with special chars like %)
PG_HOST=localhost
PG_PORT=5432
PG_USER=vpv
PG_PASSWORD=<STRONG_PASSWORD>
PG_DATABASE=ligavpv
DATABASE_POOL_SIZE=20
DATABASE_MAX_OVERFLOW=30

# Auth — generate with: python3 -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=<GENERATE_64_CHAR_RANDOM>

# CORS — only the production domain
CORS_ORIGINS=["https://ligavpv.com"]

# Invites
INVITE_BASE_URL=https://ligavpv.com/registro

# Telegram
TELEGRAM_ENABLED=true
TELEGRAM_BOT_TOKEN=<BOT_TOKEN>
TELEGRAM_CHAT_ID=<CHAT_ID>

# Scraping
SCRAPING_BASE_URL=https://www.futbolfantasy.com
SCRAPING_SEASON_SLUG=laliga-25-26
SCRAPING_POLL_INTERVAL_SECONDS=900

# ─── Frontend (PM2 / Next.js) ─────────────────────────────
# NEXT_PUBLIC_API_URL=https://ligavpv.com/api
# NEXTAUTH_URL=https://ligavpv.com
# NEXTAUTH_SECRET=<GENERATE_64_CHAR_RANDOM>
# API_INTERNAL_URL=http://127.0.0.1:8000/api
